# Frontend Environment Variables
# Copy this file to .env.local and fill in actual values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_PATH=/api/v1

# App Configuration
NEXT_PUBLIC_APP_NAME=ConektaBots
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_DESCRIPTION=SaaS platform para automação de bots Telegram

# Supabase (futuro - deixar em branco por enquanto)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Analytics (opcional)
NEXT_PUBLIC_ANALYTICS_ID=
