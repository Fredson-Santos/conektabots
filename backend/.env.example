# Configuração de Fuso Horário
TZ=America/Sao_Paulo

# Porta do Painel Web
WEB_PORT=8005

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL de conexão com o PostgreSQL (Supabase)
# Pooler (recomendado para produção):
DATABASE_URL=postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# Direto (para migrations):
# DATABASE_URL=postgresql://postgres:SENHA@db.xxxx.supabase.co:5432/postgres

# ── Criptografia ─────────────────────────────────────────────
ENCRYPTION_KEY=

# ── Shopee (Opcional) ────────────────────────────────────────
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
# ── Google APIs (MCP Stitch) ──────────────────────────────
GOOGLE_API_KEY=<REPLACE_WITH_GOOGLE_API_KEY>